# FinRAG Agent - Environment Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME="FinRAG Agent"
APP_VERSION="1.0.0"
APP_ENV="development"  # development | production
DEBUG=true
LOG_LEVEL="INFO"

# API Server
HOST="0.0.0.0"
PORT=8000

# Ollama Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="mistral"          # Model for generation (mistral, llama3.2, phi3, etc.)
OLLAMA_EMBED_MODEL="nomic-embed-text"  # Model for embeddings

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIR="./data/vectors"
CHROMA_COLLECTION_NAME="financial_docs"

# Document Storage
PDF_UPLOAD_DIR="./data/pdfs"
MAX_FILE_SIZE_MB=50

# Text Splitting Parameters
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG Parameters
TOP_K_RESULTS=5              # Number of chunks to retrieve
SIMILARITY_THRESHOLD=0.3     # Minimum similarity score

# SQLite Database
DATABASE_URL="sqlite+aiosqlite:///./data/finrag.db"
